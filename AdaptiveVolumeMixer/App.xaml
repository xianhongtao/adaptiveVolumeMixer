<Application x:Class="AdaptiveVolumeMixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdaptiveVolumeMixer.Converters">
    <Application.Resources>
        <!-- 全局转换器 -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:NullToBoolConverter x:Key="NullToBool"/>
        <converters:LevelIndexToColorBrushConverter x:Key="LevelIndexToColor"/>

        <!-- 全局状态颜色 -->
        <SolidColorBrush x:Key="PlayingColor"
                Color="#4CAF50"/>
        <SolidColorBrush x:Key="SuppressedColor"
                Color="#FF9800"/>
        <SolidColorBrush x:Key="IdleColor"
                Color="#9E9E9E"/>
    </Application.Resources>
</Application>
